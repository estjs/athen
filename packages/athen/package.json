{
  "name": "athen",
  "version": "0.0.9-beta.1",
  "description": "Vite & Essor document framework",
  "type": "module",
  "keywords": [
    "md",
    "mdx",
    "essor",
    "document",
    "vite"
  ],
  "license": "MIT",
  "homepage": "https://github.com/estjs/athen#readme",
  "bugs": "https://github.com/estjs/athen/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/estjs/athen.git"
  },
  "author": "jiangxd <jiangxd2016@gmail.com>",
  "funding": "https://github.com/sponsors/estjs",
  "files": [
    "bin",
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "sideEffects": false,
  "bin": {
    "athen": "bin/athen.js"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit -p ./tsconfig.json"
  },
  "dependencies": {
    "@estjs/athen-plugin-analytics": "workspace:*",
    "@estjs/athen-plugin-mdx": "workspace:*",
    "@estjs/athen-plugin-search": "workspace:*",
    "@iconify-json/carbon": "^1.2.23",
    "@polka/compression": "^1.0.0-next.25",
    "@svgr/core": "8.1.0",
    "@unocss/preset-icons": "^66.7.2",
    "b-tween": "^0.3.3",
    "babel-plugin-essor": "^0.0.17-beta.4",
    "cac": "^7.0.0",
    "copy-to-clipboard": "4.0.2",
    "dayjs": "^1.11.21",
    "essor": "^0.0.17-beta.4",
    "essor-router": "^0.0.18-beta.1",
    "fs-extra": "^11.3.5",
    "github-slugger": "^2.0.0",
    "glob": "^13.0.6",
    "picocolors": "^1.1.1",
    "polka": "^1.0.0-next.28",
    "sirv": "^3.0.2",
    "unhead": "^3.1.4",
    "unocss": "^66.7.2",
    "vite": "^8.0.16",
    "vite-plugin-environment": "^1.1.3",
    "vite-plugin-inspect": "^11.4.1"
  },
  "devDependencies": {
    "@babel/core": "^8.0.0",
    "@babel/types": "^7.29.7",
    "@estjs/tools": "^0.2.0",
    "@types/babel__core": "^7.20.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
