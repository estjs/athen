{
  "name": "create-athen",
  "version": "0.0.8-beta.8",
  "packageManager": "pnpm@11.2.1",
  "description": "create template for athen",
  "type": "module",
  "keywords": [
    "vite",
    "cli",
    "template"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/estjs/athen.git",
    "directory": "packages/create-athen"
  },
  "files": [
    "bin",
    "dist",
    "template"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "create-athen": "./bin/index.js"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit -p ./tsconfig.json"
  },
  "dependencies": {
    "execa": "9.6.1",
    "kolorist": "^1.8.0",
    "minimist": "^1.2.8",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.9.1",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.1",
    "vite": "^8.0.13"
  },
  "lint-staged": {
    "**/*.{js,jsx,tsx,ts,json}": [
      "eslint --fix"
    ]
  }
}
